# Neon PostgreSQL — pooled connection string
# console.neon.tech → your project → Connection string (pooled)
DATABASE_URL=postgresql://user:password@ep-xxxx.ap-south-1.aws.neon.tech/neondb?sslmode=require

# Cloudflare credentials — only needed for deploying the worker, creating the R2
# bucket, and (later) managing Pages projects / custom domains. Local dev with
# `wrangler dev` does NOT need these — miniflare simulates everything offline.
#
# Account ID:  dash.cloudflare.com → right sidebar of any page → "Account ID"
# API Token:   dash.cloudflare.com → My Profile → API Tokens → Create Token →
#              Custom token with these permissions on your account:
#                - Workers Scripts: Edit
#                - Workers R2 Storage: Edit
#                - Cloudflare Pages: Edit
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Your deployed worker URL — used when building the site template for production.
# Set this after deploying the worker, then run `npm run upload-template`.
# Example: https://gonex-builder-api.your-subdomain.workers.dev
WORKER_URL=
