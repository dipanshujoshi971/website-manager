# OPTIONAL — dev-only override.
# In production, the site resolves which client it's serving from window.location.hostname
# via GET /api/sites/resolve?host=... — no build-time site ID needed. A single Pages
# deployment serves every client (custom domains + *.pages.dev subdomains).
# Set this only when running `/site` on localhost and you want to preview a specific site.
# VITE_SITE_ID=your-site-id

# In dev: leave empty — the vite proxy forwards /api calls to localhost:8787
# In production: set to your deployed worker URL
# VITE_API_URL=https://your-worker.workers.dev
