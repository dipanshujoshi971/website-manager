{
  "routes": [
    {
      "route": "/api/*",
      "rewrite": "https://gonex-builder-api.keshavgoyal5.workers.dev/api/*"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/assets/*", "*.{css,js,svg,png,jpg,jpeg,gif,ico,webp,woff,woff2}"]
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
