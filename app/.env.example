# URL of the running Hono worker (local or deployed)
VITE_API_URL=http://localhost:8787

# Your deployed worker URL — used to send Deploy requests directly to production
# (local dev worker can't access the real R2 bucket, so deploy bypasses the proxy)
VITE_WORKER_URL=https://gonex-builder-api.keshavgoyal5.workers.dev

# Where the /site template is served. Used by the live preview iframe in the editor
# and the standalone /preview/:siteId page when a project has no per-site previewUrl.
# Dev: http://localhost:5173. Prod: your deployed Pages URL, e.g. https://gonex-sites.pages.dev
VITE_SITE_PREVIEW_URL=http://localhost:5173
